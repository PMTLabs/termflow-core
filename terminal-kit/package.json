{
  "name": "terminal-kit",
  "version": "1.0.0",
  "description": "CLI tool to initialize multi-team agent workflow assets for AI orchestration",
  "type": "module",
  "bin": {
    "tk": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build",
    "postinstall": "npm run build || true"
  },
  "keywords": [
