# Dev wiring — connects the Terminal Monitor to the Tauri DEV build (`tauri dev`),
# whose embedded API + WebSocket server listens on port 42051.
# (The production .app uses 42031 — see src-tauri/src/app_config.rs default_api_port.)
#
# Auto-loaded by `react-scripts start` (i.e. `bun run start`) in development.
# No secrets here — localhost mode leaves the API open (auth is enforced only
# when "expose on network" is enabled), so no token is required.
REACT_APP_API_URL=http://localhost:42051
REACT_APP_WS_URL=ws://localhost:42051/ws
