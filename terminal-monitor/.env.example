# API Configuration
# Port 42031 = production .app; the Tauri DEV build (`tauri dev`) uses 42051.
# For local dev you don't need to copy this file — `.env.development` already
# wires the monitor to the dev port (42051) automatically on `bun run start`.
REACT_APP_API_URL=http://localhost:42031
REACT_APP_WS_URL=ws://localhost:42031/ws

# Environment
REACT_APP_ENV=development

# Version (automatically populated from package.json)
REACT_APP_VERSION=$npm_package_version

# Feature Flags
REACT_APP_ENABLE_DEBUG=false
REACT_APP_ENABLE_ANALYTICS=false

# Terminal Settings
REACT_APP_MAX_TERMINALS=20
REACT_APP_DEFAULT_SHELL=cmd

# WebSocket Settings
REACT_APP_WS_RECONNECT_ATTEMPTS=10
REACT_APP_WS_RECONNECT_DELAY=1000

# UI Settings
REACT_APP_THEME=dark
REACT_APP_TERMINAL_FONT_SIZE=14