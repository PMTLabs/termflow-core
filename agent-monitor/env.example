# Auto-Terminal API Configuration
API_URL=http://localhost:3001
WS_URL=ws://localhost:9876

# IMPORTANT: You need a valid token from the running Auto-Terminal instance
# See get-valid-token.js for instructions on how to obtain one
API_TOKEN=your-token-here

# For development: You can use a fixed JWT secret in Auto-Terminal
# by modifying src/main/main.ts and adding to API_CONFIG:
# jwtSecret: 'dev-secret-do-not-use-in-production'
# Then generate a token with the same secret

# Discord Alerts Configuration
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Default Terminal Tab Configuration  
DEFAULT_TERMINAL_TABID=your-default-tab-id