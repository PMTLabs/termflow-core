{
  "name": "auto-terminal",
  "version": "0.1.0",
  "description": "Cross-platform terminal emulator with developer API",
  "workspaces": ["terminal-monitor", "packages/*"],
  "scripts": {
    "postinstall": "node patches/xterm-dim-patch.js",
    "patch:xterm-dim": "node patches/xterm-dim-patch.js",
    "build:renderer": "cross-env NODE_ENV=production webpack --config webpack.renderer.config.js",
    "build:terminal-core": "bun --filter @termflow/terminal-core build",
    "build": "bun run build:terminal-core && bun run build:renderer",
    "start": "tauri dev",
    "dev:renderer": "webpack serve --config webpack.renderer.config.js",
    "dev": "tauri dev",
    "tauri": "tauri",
    "dev:tauri": "tauri dev",
    "build:pty-host": "cargo build --manifest-path src-tauri/pty-host/Cargo.toml --release",
    "dev:pty-host": "bun run build:pty-host && cross-env TERMFLOW_PTY_HOST=1 tauri dev",
    "build:mcp-sidecar": "bun scripts/build-mcp-sidecar.mjs",
    "build:fabric-sidecar": "bun scripts/build-fabric-sidecar.mjs",
    "build:pty-host-sidecar": "bun scripts/build-pty-host-sidecar.mjs",
    "build:sidecars:pro": "bun run build:fabric-sidecar && bun run build:pty-host-sidecar",
    "gen:third-party-notices": "node scripts/gen-third-party-notices.mjs",
    "gen:eula-rtf": "node scripts/gen-eula-rtf.mjs",
    "build:tauri": "tauri build --no-bundle",
    "publish:tauri": "tauri build",
    "build:tauri:arm64": "tauri build --no-bundle --target aarch64-pc-windows-msvc",
    "publish:tauri:arm64": "tauri build --target aarch64-pc-windows-msvc",
    "dev:pro": "bun run build:sidecars:pro && tauri dev --config src-tauri/tauri.pro.conf.json",
    "build:tauri:pro": "bun run build:sidecars:pro && tauri build --no-bundle --config src-tauri/tauri.pro.conf.json",
    "publish:tauri:pro": "bun run build:sidecars:pro && tauri build --config src-tauri/tauri.pro.conf.json",
    "publish:tauri:pro:alt": "bun run build:sidecars:pro && cross-env CARGO_TARGET_DIR=target-pro-alt tauri build --config src-tauri/tauri.pro.conf.json",
    "build:tauri:pro:arm64": "cross-env TERMFLOW_RUST_TARGET=aarch64-pc-windows-msvc bun run build:sidecars:pro && tauri build --no-bundle --target aarch64-pc-windows-msvc --config src-tauri/tauri.pro.conf.json",
    "publish:tauri:pro:arm64": "cross-env TERMFLOW_RUST_TARGET=aarch64-pc-windows-msvc bun run build:sidecars:pro && tauri build --target aarch64-pc-windows-msvc --config src-tauri/tauri.pro.conf.json",
    "test": "jest",
    "test:workspace": "bun --filter @termflow/terminal-core test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test && npm run test:e2e",
    "smoke:release": "bun scripts/smoke-test-release.mjs",
    "mcp": "node mcp-server/build/index.js",
    "mcp:dev": "cd mcp-server && npm run dev"
  },
  "keywords": [
    "terminal",
    "emulator",
    "tauri",
    "cross-platform"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@tauri-apps/cli": "^2.9.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.14",
    "@types/ws": "^8.18.1",
    "buffer": "^6.0.3",
    "jest-environment-jsdom": "^30.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "events": "^3.3.0",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^30.0.4",
    "playwright": "^1.54.1",
    "process": "^0.11.10",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "util": "^0.12.5",
    "webpack": "^5.100.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "@termflow/terminal-core": "workspace:*",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@reduxjs/toolkit": "^2.8.2",
    "@tauri-apps/api": "2.9.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "~2.6.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/uuid": "^10.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "jsonwebtoken": "^9.0.2",
    "react": "^19.1.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.1.0",
    "react-redux": "^9.2.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.3"
  }
}
